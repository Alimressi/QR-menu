+// Shim: @prisma/client@6.16.2 declares an ESM "import" condition for ./wasm that
+// points at this file, but the generator only ships wasm.js (CJS). Bundlers
+// (Turbopack/webpack) resolve `@prisma/client/wasm` through the "import" branch,
+// so this file must exist and re-export the CJS module.
+//
+// It is used by the Cloudflare-Workers branch of src/lib/prisma.ts. Use a STATIC
+// default import so the bundler inlines wasm.js at build time — a runtime
+// createRequire("./wasm.js") works in Node but throws `No such module "wasm.js"`
+// on Cloudflare Workers, which have no dynamic require.
+//
+// Not committed directly (node_modules); applied via patches/ + patch-package.
+import mod from "./wasm.js";
+
+export const {
+  Prisma,
+  $Enums,
+  PrismaClient,
+  prismaVersion,
+  PrismaClientKnownRequestError,
+  PrismaClientUnknownRequestError,
+  PrismaClientRustPanicError,
+  PrismaClientInitializationError,
+  PrismaClientValidationError,
+  Decimal,
+  sql,
+  empty,
+  join,
+  raw,
+  validator,
+  getExtensionContext,
+  defineExtension,
+  DbNull,
+  JsonNull,
+  AnyNull,
+  NullTypes,
+  TransactionIsolationLevel,
+  ModelName,
+} = mod;
+
+export default mod;
