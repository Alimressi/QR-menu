+// Local dev shim: @prisma/client@6.16.2 declares an ESM "import" condition for
+// ./wasm pointing at this file, but the package/generator only ships wasm.js (CJS),
+// so bundlers (Turbopack/webpack) fail to resolve `@prisma/client/wasm` during
+// `next dev`. This re-exports the CJS module so the ESM path resolves. It is only
+// referenced from the Cloudflare-Workers branch of src/lib/prisma.ts and never runs
+// under local Node. Not committed (node_modules); regenerate if reinstalling deps.
+import { createRequire } from "module";
